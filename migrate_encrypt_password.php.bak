<?php
/**
 * Migration Script: Encrypt existing mikrotik_password
 * 
 * Run this script ONCE after updating the code to encrypt
 * any existing plaintext passwords in the settings table.
 * 
 * Usage: php migrate_encrypt_password.php
 */

require_once __DIR__ . '/config.php';

// Access Control: CLI or Admin only
$is_cli = (php_sapi_name() === 'cli');
if (!$is_cli) {
    if (!isset($_SESSION['user_id'])) {
        die("Forbidden");
    }
    if ($_SESSION['role'] !== 'Administrator') {
        die("Access Denied");
    }
}

echo "==============================================\n";
echo "Password Encryption Migration Script\n";
echo "==============================================\n\n";

try {
    // Get current password
    $stmt = $pdo->prepare("SELECT setting_value FROM settings WHERE setting_key = 'mikrotik_password'");
    $stmt->execute();
    $currentPassword = $stmt->fetchColumn();

    if (empty($currentPassword)) {
        echo "⚠️  No mikrotik_password found in settings table.\n";
        echo "   Nothing to migrate.\n";
        exit(0);
    }

    // Check if already encrypted (try to detect base64 pattern)
    $decoded = base64_decode($currentPassword, true);
    if ($decoded !== false && strlen($decoded) > 16) {
        // Likely already encrypted (base64 with IV + data)
        echo "⚠️  Password appears to already be encrypted.\n";
        echo "   Skipping migration.\n";
        exit(0);
    }

    // Encrypt the password
    $encryptedPassword = encrypt_data($currentPassword);

    // Update in database
    $updateStmt = $pdo->prepare("UPDATE settings SET setting_value = ? WHERE setting_key = 'mikrotik_password'");
    $updateStmt->execute([$encryptedPassword]);

    echo "✅ Password successfully encrypted!\n";
    echo "   Original length: " . strlen($currentPassword) . " chars\n";
    echo "   Encrypted length: " . strlen($encryptedPassword) . " chars\n";
    echo "\n";
    
    // Verify decryption works
    $decrypted = decrypt_data($encryptedPassword);
    if ($decrypted === $currentPassword) {
        echo "✅ Verification passed - decryption works correctly.\n";
    } else {
        echo "❌ WARNING: Decryption verification failed!\n";
        echo "   Please check your ENCRYPTION_KEY constant.\n";
    }

} catch (Exception $e) {
    echo "❌ Error: " . $e->getMessage() . "\n";
    exit(1);
}

echo "\n==============================================\n";
echo "Migration complete!\n";
echo "==============================================\n";
?>
